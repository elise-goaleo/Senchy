generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // Accelerate (prisma+postgres://…) — runtime
  directUrl = env("DIRECT_URL")     // connexion directe (postgres://…@db.prisma.io) — migrations/studio en local
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String    @map("password_hash")
  avatarUrl    String?   @map("avatar_url")
  createdAt    DateTime  @default(now()) @map("created_at")
  trips        Trip[]
  accounts     Account[]
  sessions     Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Trip {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  name           String
  type           String    @default("biketrip") // 'biketrip' | 'roadtrip'
  description    String?
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  coverImageUrl      String?   @map("cover_image_url")
  coverImagePosition String?   @map("cover_image_position") // e.g. "50% 30%"
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments    Segment[]
  pois        Poi[]
  stopovers   Stopover[]

  @@map("trips")
}

model Stopover {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  sortOrder Int      @default(0) @map("sort_order")
  date      DateTime  @db.Date
  endDate   DateTime? @db.Date @map("end_date")
  name      String?
  place     String?
  notes     String?
  platform  String?  // 'booking' | 'airbnb' | null (autre)
  link      String?  // URL de réservation
  createdAt DateTime @default(now()) @map("created_at")
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("stopovers")
}

model Segment {
  id             String   @id @default(cuid())
  tripId         String   @map("trip_id")
  sortOrder      Int      @map("sort_order")
  type           String   // 'gpx' | 'train' | 'walking' | 'car' | 'visit' | 'arrival' | 'departure'
  name           String?
  transportMode  String?  @map("transport_mode") // arrivée/départ : 'Avion' | 'Train' | …
  terminal       String?  // arrivée/départ : terminal / gare / quai
  gpxRaw         String?  @map("gpx_raw") @db.Text
  geojson        Json?
  distanceM      Float?   @map("distance_m")
  elevationGainM Float?   @map("elevation_gain_m")
  elevationLossM Float?   @map("elevation_loss_m")
  elevationPoints Json?   @map("elevation_points")
  startLat       Float?   @map("start_lat")
  startLon       Float?   @map("start_lon")
  origin         String?
  destination    String?
  durationMin    Int?     @map("duration_min")
  departureAt    DateTime? @map("departure_at")
  arrivalAt      DateTime? @map("arrival_at")
  notes          String?   @db.Text
  komootUrl      String?   @map("komoot_url")
  createdAt      DateTime @default(now()) @map("created_at")
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("segments")
}

model Poi {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  category  String   // 'supermarket' | 'toilet' | 'sight' | 'custom'
  name      String?
  lat       Float
  lon       Float
  osmId     BigInt?  @map("osm_id")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("pois")
}

model WeatherCache {
  id           String   @id @default(cuid())
  lat          Float
  lon          Float
  forecastDate DateTime @map("forecast_date") @db.Date
  payload      Json
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@unique([lat, lon, forecastDate])
  @@map("weather_cache")
}
